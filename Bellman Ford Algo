//T(V,E)=O(V×E)

import java.util.Arrays;
import java.util.Scanner;

class Edge{
    int src, dest, wt;
    Edge(int s, int d, int w){
        this.src = s;
        this.dest = d;
        this.wt = w;
    }
}


public class Assignment6 {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number of vertices");
        int v = sc.nextInt();

        System.out.println("Enter number of edges");
        int e = sc.nextInt();

        System.out.println("Edges: ");
        Edge edges[] = new Edge[e];
        for(int i=0; i< e; i++){
            int s = sc.nextInt();
            int d = sc.nextInt();
            int w = sc.nextInt();
            edges[i] = new Edge(s, d, w);
        }

        System.out.println("Enter source vertex ");
        int src = sc.nextInt();

        bellmanFord(v, e, edges, src);
    }

    public static void bellmanFord(int V, int e, Edge[] edges, int src){
        int dist[] = new int[V];
        int parent[] = new int[V];

        Arrays.fill(dist, Integer.MAX_VALUE);
        Arrays.fill(parent, -1);
        dist[src] = 0;

        for(int i=1; i<V; i++){
            for (int j=0; j<e; j++){
                int u = edges[j].src;
                int v = edges[j].dest;
                int w = edges[j].wt;

                if(dist[u] != Integer.MAX_VALUE && dist[u]+w < dist[v]){
                    dist[v] = dist[u] + w;
                    parent[v] = u;
                }
            }
        }

        for (int j=0; j<e; j++){
            int u = edges[j].src;
            int v = edges[j].dest;
            int w = edges[j].wt;

            if(dist[u] != Integer.MAX_VALUE && dist[u]+w < dist[v]){
                System.out.println("Graph contains negative weight cycle");
                return;
            }
        }

        System.out.println("Vertex\tDistance\tPath");
        for (int i=0; i < V; i++){
            System.out.print(i + "\t"+ dist[i] + "\t\t");
            printPath(parent, i);
            System.out.println();
        }
    }
    public static  void printPath(int parent[], int v){
        if(v == -1)return;
        printPath(parent, parent[v]);
        System.out.print(v + " ");
    }

}
